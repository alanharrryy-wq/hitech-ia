{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hitech.govos.status.v1",
  "title": "GOVOS Status Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["doc_id", "status", "summary", "updated_on"],
  "properties": {
    "doc_id": {
      "type": "string",
      "minLength": 3
    },
    "status": {
      "type": "string",
      "enum": ["OK", "WARN", "BLOCKED", "FAIL"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "updated_on": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "owner": {
      "type": "string"
    }
  }
}
