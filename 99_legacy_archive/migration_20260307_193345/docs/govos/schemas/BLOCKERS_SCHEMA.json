{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hitech.govos.blockers.v1",
  "title": "GOVOS Blockers Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["blocker_id", "severity", "message", "owner"],
        "properties": {
          "blocker_id": {
            "type": "string",
            "minLength": 3
          },
          "severity": {
            "type": "string",
            "enum": ["BLOCKED", "FAIL"]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "evidence_path": {
            "type": "string"
          }
        }
      }
    }
  }
}
